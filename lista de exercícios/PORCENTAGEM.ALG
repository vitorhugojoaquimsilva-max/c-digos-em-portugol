Algoritmo "calculos"

Var
n1, n2, soma, sub: inteiro
mult, divi: real

Inicio

escreva("informe o primeiro número: ")
leia(n1)
escreva("informe o segundo número: ")
leia(n2)

soma <- n1 + n2
sub <- n1 - n2
mult <- n1 * n2
divi <- n1 / n2

escreval("soma: ", soma)
escreval("subtração: ", sub)
escreval("multiplicação: ", mult)
escreval("divisão: ", divi)
Fimalgoritmo